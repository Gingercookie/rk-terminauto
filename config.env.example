# Copy to config.env and fill in. config.env is gitignored (contains secrets).

# 2captcha API key (https://2captcha.com -> Dashboard). Fund a few dollars.
TWOCAPTCHA_API_KEY=your_2captcha_key_here

# ntfy topic to push to. Install the ntfy app and subscribe to this exact name.
# Keep it unguessable — anyone who knows the topic can read your pushes.
NTFY_TOPIC=rk-termin-losa-47493de1

# Optional overrides (defaults shown):
# NTFY_SERVER=https://ntfy.sh
# RK_LOCATION_CODE=losa
# RK_REALM_ID=1363
# RK_CATEGORY_ID=3301
# RK_LOCALE=en
