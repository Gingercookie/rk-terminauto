<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rkterminauto.poll</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/wgraham/personal/rk-terminauto/run.sh</string>
    </array>

    <!-- Ensure Homebrew's uv is on PATH under launchd's minimal environment. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- poll.py is a long-running daemon (it manages its own tiered polling
         schedule internally). launchd just keeps it alive and restarts it on
         crash or after reboot. -->
    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <!-- Don't hammer restarts if it crash-loops. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/wgraham/personal/rk-terminauto/poll.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/wgraham/personal/rk-terminauto/poll.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/wgraham/personal/rk-terminauto</string>
</dict>
</plist>
